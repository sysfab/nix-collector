<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
	<id>sysfab.nix.collector.desktop</id>
	<name translate="no">Nix-Collector</name>
    <summary>Nix-focused fork of Collector for drag-and-drop workflows</summary>
    <url type="homepage">https://github.com/sysfab/nix-collector</url>
    <url type="bugtracker">https://github.com/sysfab/nix-collector/issues</url>
    <url type="vcs-browser">https://github.com/sysfab/nix-collector</url>
    <url type="translate">https://github.com/sysfab/nix-collector/tree/master/po</url>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-or-later</project_license>
    <developer id="io.github.sysfab">
        <name translate="no">sysfab</name>
    </developer>
    <description>
        <p>Nix-Collector is a Nix-focused fork of Collector that lets you drag multiple files into a single window and drop them anywhere.</p>
        <p>Original project by Lorenzo Paderi.</p>
    </description>
    <translation type="gettext">collector</translation>
    <launchable type="desktop-id">sysfab.nix.collector.desktop</launchable>
	<releases>
        <release type="stable" version="1.0.3" date="2026-02-03T00:00:00Z">
            <description translate="no">
                <p>- Updated to SDK 49 (Finally)</p>
                <p>- Small UI touches</p>
            </description>
        </release>
		<release type="stable" version="1.0.2" date="2024-08-02T00:00:00Z">
            <description translate="no">
                <p>- New icon! By Jakub Steiner</p>
            </description>
        </release>
        <release type="stable" version="1.0.1" date="2024-02-05T00:00:00Z">
            <description translate="no">
                <p>- Added translations</p>
                <p>- Bug fix</p>
            </description>
        </release>
		<release type="stable" version="1.0.0" date="2024-01-12T00:00:00Z">
            <description translate="no">
                <p>- First release</p>
            </description>
        </release>
	</releases>
    <screenshots>
        <screenshot type="default">
            <caption>Application showcase</caption>
            <image type="source">
                https://raw.githubusercontent.com/mijorus/collector/master/docs/collector-preview-1.png</image>
        </screenshot>
        <screenshot>
